<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/inventory_category"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/dialog_inv_category_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_marginTop="6dp" />

    <EditText
        android:id="@+id/dialog_inv_item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/inventory_item_name"
        android:inputType="textPersonName" />

    <EditText
        android:id="@+id/dialog_inv_stock_qty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/inventory_stock_qty"
        android:inputType="number" />

    <EditText
        android:id="@+id/dialog_inv_min_stock_qty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/inventory_min_stock_qty"
        android:inputType="number" />

</LinearLayout>

