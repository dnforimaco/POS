<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pos_warm_bg"
    tools:context=".ui.inventory.InventoryFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="14dp"
        android:background="@color/pos_card_bg"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/inventory_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings_back"
            app:srcCompat="@drawable/ic_arrow_back_24"
            app:tint="@color/pos_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/inventory_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#212121" />
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/inventory_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pos_warm_bg"
        app:tabIndicatorColor="@color/pos_primary"
        app:tabSelectedTextColor="@color/pos_primary"
        app:tabTextColor="@color/card_category_subtitle" />

    <!-- Items panel -->
    <LinearLayout
        android:id="@+id/panel_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <Spinner
                android:id="@+id/inventory_category_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="48dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inventory_add_category"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inventory_add_category" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inventory_add_item"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inventory_add_item" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/inventory_export_report"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/inventory_export_report" />

        <LinearLayout
            android:id="@+id/inventory_table_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:background="@color/card_category_bg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.3"
                android:text="@string/inventory_item_name"
                android:textStyle="bold"
                android:textColor="@color/card_category_text" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:text="@string/inventory_category"
                android:textStyle="bold"
                android:textColor="@color/card_category_text" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:gravity="center"
                android:text="@string/inventory_stock_status"
                android:textStyle="bold"
                android:textColor="@color/card_category_text" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"
                android:gravity="center"
                android:text="@string/inventory_stock_qty"
                android:textStyle="bold"
                android:textColor="@color/card_category_text" />

            <TextView
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="@string/inventory_action"
                android:textStyle="bold"
                android:textColor="@color/card_category_text" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/inventory_items_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_inventory_item" />
    </LinearLayout>

    <!-- History panel -->
    <LinearLayout
        android:id="@+id/panel_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/inventory_clear_history"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:text="@string/inventory_clear_history"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/inventory_history_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_inventory_history" />
    </LinearLayout>

</LinearLayout>
