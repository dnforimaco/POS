<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="@color/pos_card_bg"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.3"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/inv_item_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:text="Item name" />
    </LinearLayout>

    <TextView
        android:id="@+id/inv_item_category"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/card_category_subtitle"
        android:text="Category" />

    <TextView
        android:id="@+id/inv_item_stock_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.9"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/price_red"
        android:text="OUT OF STOCK" />

    <TextView
        android:id="@+id/inv_item_stock_qty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="@color/black"
        android:text="0" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/inv_btn_restock"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/inventory_restock" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/inv_btn_more"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="⋮" />
</LinearLayout>

