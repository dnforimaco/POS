<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pos_warm_bg"
    tools:context=".ui.settings.SettingsFragment">

    <!-- Top bar with back -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="14dp"
        android:background="@color/pos_card_bg"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/settings_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings_back"
            app:srcCompat="@drawable/ic_arrow_back_24"
            app:tint="@color/pos_primary" />

        <TextView
            android:id="@+id/settings_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/settings_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#212121" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Restaurant Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/pos_card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_restaurant"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/pos_primary_dark" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_restaurant_name"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_restaurant_name_value"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:lineSpacingExtra="2dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/settings_restaurant_address"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_restaurant_address_value"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:lineSpacingExtra="2dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/settings_restaurant_contact"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_restaurant_contact_value"
                        android:textSize="15sp"
                        android:textColor="#212121" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Management (Manager only) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settings_card_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/pos_card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_menu"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/pos_primary_dark" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/settings_menu_add_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_menu_add_edit_delete"
                        android:textAllCaps="false"
                        android:insetTop="10dp"
                        android:insetBottom="10dp"
                        android:layout_marginBottom="10dp"
                        app:icon="@android:drawable/ic_menu_edit"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:backgroundTint="@color/card_category_bg"
                        app:iconTint="@color/pos_primary_dark"
                        android:textColor="#212121" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/settings_menu_prices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_menu_prices"
                        android:textAllCaps="false"
                        android:insetTop="10dp"
                        android:insetBottom="10dp"
                        android:layout_marginBottom="10dp"
                        app:icon="@android:drawable/ic_menu_sort_by_size"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:backgroundTint="@color/card_category_bg"
                        app:iconTint="@color/pos_primary_dark"
                        android:textColor="#212121" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/settings_menu_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_menu_categories"
                        android:textAllCaps="false"
                        android:insetTop="10dp"
                        android:insetBottom="10dp"
                        app:icon="@android:drawable/ic_input_add"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:backgroundTint="@color/card_category_bg"
                        app:iconTint="@color/pos_primary_dark"
                        android:textColor="#212121" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User Accounts (Manager only) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settings_card_users"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/pos_card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_users"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/pos_primary_dark" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/settings_change_password"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_change_password"
                        app:strokeColor="@color/pos_primary_dark"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Printer Settings -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/pos_card_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_section_printer"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/pos_primary_dark" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_printer_guideline"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#424242"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/settings_printer_guideline_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_printer_guideline_text"
                        android:textSize="14sp"
                        android:textColor="#616161"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
