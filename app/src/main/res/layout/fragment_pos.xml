<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pos_warm_bg">

    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/nav_rail"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:backgroundTint="@color/pos_card_bg"
        app:menu="@menu/pos_rail"
        app:itemIconTint="@color/pos_nav_item"
        app:itemTextColor="@color/pos_nav_item"
        app:labelVisibilityMode="labeled" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_cart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="@dimen/pos_cart_width" />

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toEndOf="@id/nav_rail"
        app:layout_constraintEnd_toStartOf="@id/guideline_cart"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/pos_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pos_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#212121"
            android:paddingEnd="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/pos_search_hint"
            app:endIconMode="clear_text"
            app:boxStrokeColor="@color/pos_primary"
            app:boxBackgroundColor="@color/pos_card_bg">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/search_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionSearch" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabs_categories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/pos_warm_bg"
        app:tabMode="scrollable"
        app:tabIndicatorColor="@color/pos_primary"
        app:tabSelectedTextColor="@color/pos_primary"
        app:tabTextColor="#6D6D6D"
        app:layout_constraintStart_toEndOf="@id/nav_rail"
        app:layout_constraintEnd_toStartOf="@id/guideline_cart"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <TextView
        android:id="@+id/search_scope_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:text="@string/pos_search_all_categories"
        android:textSize="12sp"
        android:textColor="#757575"
        app:layout_constraintStart_toEndOf="@id/nav_rail"
        app:layout_constraintEnd_toStartOf="@id/guideline_cart"
        app:layout_constraintTop_toBottomOf="@id/tabs_categories" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_products"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="10dp"
        android:clipToPadding="false"
        app:layout_constraintStart_toEndOf="@id/nav_rail"
        app:layout_constraintEnd_toStartOf="@id/guideline_cart"
        app:layout_constraintTop_toBottomOf="@id/search_scope_banner"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_pos_product" />

    <LinearLayout
        android:id="@+id/cart_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/pos_card_bg"
        app:layout_constraintStart_toStartOf="@id/guideline_cart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/cart_header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="58dp"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp"
            android:background="@color/pos_card_bg">

            <TextView
                android:id="@+id/cart_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:text="@string/cart_title"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#212121" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cart_toggle"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                app:iconTint="@color/pos_primary"
                app:backgroundTint="@color/card_category_bg"
                app:iconPadding="0dp"
                app:iconGravity="textStart" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_cart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="10dp"
            tools:listitem="@layout/item_cart" />

        <TextView
            android:id="@+id/cart_empty_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="@string/cart_empty"
            android:textColor="#757575"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/cart_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:animateLayoutChanges="true"
            android:paddingStart="10dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            android:background="@color/pos_warm_bg">

            <TextView
                android:id="@+id/cart_pending_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="13sp"
                android:textColor="@color/pos_primary_dark"
                android:textStyle="bold"
                tools:text="Editing order #12"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/cart_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/cart_total"
                android:textColor="@color/price_red"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="46dp"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:text="@string/cart_clear"
                    app:cornerRadius="22dp"
                    app:strokeColor="@color/card_category_subtitle"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_kitchen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:minHeight="46dp"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:text="@string/pos_send_to_kitchen"
                    app:cornerRadius="22dp"
                    app:backgroundTint="@color/pos_primary" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
